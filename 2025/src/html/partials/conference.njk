{% macro conferenceCard(data) %}
<div class="col">
    <div class="card conf">
        {% if (data.thumbnail and data.videoUrl) %}
        <a href="{{data.videoUrl}}" title="Voir la conférence">
            <img src="{{data.thumbnail}}" class="card-img-top" alt="{{data.title}}">
			<img src="./img/play.svg" width="50" class="play-logo" >
        </a>
        {% endif %}
        <div class="card-body">
            <h4>
            {% if (data.id) %}{{data.id}} &dash; {% endif %}
            {{data.title}}
            </h4>
            <h5 class="text-muted">{{data.author}}</h5>
            {% endif %}
        </div>
    </div>
</div>
{% endmacro %}
